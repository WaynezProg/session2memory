{
  "name": "session2memory",
  "displayName": "Session2Memory",
  "version": "0.1.1",
  "description": "Compile local AI coding sessions into evidence-backed, HKS-ingestable project memory.",
  "entrypoint": "SKILL.md",
  "agents_metadata": "agents/openai.yaml",
  "compatible_agents": [
    "codex",
    "claude-code",
    "openclaw",
    "hermes",
    "vibe-code"
  ],
  "supported_tools": [
    "codex",
    "claude",
    "claude-desktop",
    "qwen",
    "opencode",
    "cursor",
    "cursor-cli",
    "openclaw",
    "hermes"
  ],
  "execution_model": {
    "mode": "manual_cli_workflow",
    "requires_human_review": true,
    "resume_source": "review/<date>.jsonl"
  },
  "commands": {
    "discover": "uv run session2memory discover",
    "import": "uv run session2memory import --date <YYYY-MM-DD> --workspace <project> --output $HKS_SESSION2MEMORY_EXPORT_ROOT/<workspace_id>",
    "review_list": "uv run session2memory review list --date <YYYY-MM-DD> --output $HKS_SESSION2MEMORY_EXPORT_ROOT/<workspace_id>",
    "review_inspect": "uv run session2memory review inspect <review-id> --date <YYYY-MM-DD> --output $HKS_SESSION2MEMORY_EXPORT_ROOT/<workspace_id>",
    "review_promote": "uv run session2memory review promote --date <YYYY-MM-DD> --output $HKS_SESSION2MEMORY_EXPORT_ROOT/<workspace_id>",
    "hks_ingest": "hks_workspace_ingest_session_memory(workspace_id=<workspace_id>, path=daily/<YYYY-MM-DD>.md)",
    "hks_query": "hks_workspace_query(workspace_id=<workspace_id>, query=<question>, writeback=no)"
  },
  "outputs": {
    "generated_source": "$HKS_SESSION2MEMORY_EXPORT_ROOT/<workspace_id>",
    "daily_log": "daily/<date>.md",
    "evidence_index": "evidence/index.jsonl",
    "review_queue": "review/<date>.jsonl",
    "promoted_memories": "memories/<workspace-id>.md"
  },
  "hks_policy": {
    "default_ks_root": "<hks-repo>/.hks-runs/session-memory/ks",
    "ingest_markdown_only": true,
    "do_not_ingest_raw_session_stores": true,
    "do_not_prune_without_user_request": true
  }
}
